{
  // Worker proxy de geracao de imagens (OpenAI) para o Kioku.
  //
  // Deploy (rode DENTRO de workers/image-proxy): `npx wrangler deploy`.
  // A chave NUNCA fica neste arquivo. Defina-a como secret:
  //   npx wrangler secret put OPENAI_API_KEY
  // Ajuste ALLOWED_ORIGINS abaixo para o seu dominio de producao do Kioku
  // (mantendo http://localhost:5173 para desenvolvimento).
  "name": "kioku-image-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "vars": {
    "ALLOWED_ORIGINS": "https://kioku.com.br,http://localhost:5173"
  }
}
